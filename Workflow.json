    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const text = $input.item.json.output[0].content[0].text\n  .replace(/```json|```/g, '')\n  .trim();\nconst persona = JSON.parse(text);\nconst lead = $('Get row(s) in sheet').item.json;\n\n// Calcul score complétude\nconst champsObligatoires = [lead.Prenom, lead.Nom, lead.email, lead.titre, lead.entreprise, lead.secteur, lead.taille_entreprise];\nconst champsRemplis = champsObligatoires.filter(c => c && c.toString().trim() !== '').length;\nconst scoreCompletude = Math.round((champsRemplis / champsObligatoires.length) * 100);\n\n// Validation domaine email\nconst domainEmail = lead.email ? lead.email.split('@')[1]?.toLowerCase() : '';\nconst nomEntreprise = lead.entreprise ? lead.entreprise.toLowerCase().replace(/\\s/g, '') : '';\nconst domainesGeneriques = ['gmail.com', 'yahoo.fr', 'yahoo.com', 'hotmail.com', 'outlook.com', 'test.com', 'example.com'];\nconst emailGenerique = domainesGeneriques.includes(domainEmail);\nconst emailCoherent = !emailGenerique && (\n  domainEmail.includes(nomEntreprise.substring(0, 4)) ||\n  nomEntreprise.includes(domainEmail.split('.')[0])\n);\nconst alerteEmail = emailGenerique\n  ? '⚠️ Email générique — vérifier le contact'\n  : !emailCoherent\n    ? '⚠️ Domaine email incohérent avec l\\'entreprise'\n    : '✅ Email vérifié';\n\n// Statut combiné\nconst statut = emailGenerique\n  ? 'À vérifier — email générique'\n  : scoreCompletude < 80\n    ? 'Données incomplètes'\n    : persona.score_confiance >= 70\n      ? 'Fiable'\n      : 'À vérifier';\n\nreturn {\n  json: {\n    // Lead\n    lead_nom: lead.Prenom + ' ' + lead.Nom,\n    lead_email: lead.email,\n    lead_titre: lead.titre,\n    lead_entreprise: lead.entreprise,\n\n    // Persona\n    nom_persona: persona.nom_persona,\n    profil: persona.profil,\n    categorie: persona.categorie,\n    style_communication: persona.style_communication,\n\n    // Scores\n    score_maturite_achat: persona.score_maturite_achat,\n    score_confiance: persona.score_confiance,\n    score_completude: scoreCompletude,\n    statut: statut,\n    alerte_email: alerteEmail,\n\n    // Arrays\n    motivations: Array.isArray(persona.motivations) ? persona.motivations.join(' | ') : persona.motivations || '',\n    objections: Array.isArray(persona.objections) ? persona.objections.join(' | ') : persona.objections || '',\n    declencheurs_achat: Array.isArray(persona.declencheurs_achat) ? persona.declencheurs_achat.join(' | ') : persona.declencheurs_achat || '',\n    canaux_preferes: Array.isArray(persona.canaux_preferes) ? persona.canaux_preferes.join(' | ') : persona.canaux_preferes || '',\n\n    // Conseils commerciaux\n    accroche_ideale: persona.conseils_commerciaux?.accroche_ideale || '',\n    arguments_cles: Array.isArray(persona.conseils_commerciaux?.arguments_cles) ? persona.conseils_commerciaux.arguments_cles.join(' | ') : persona.conseils_commerciaux?.arguments_cles || '',\n    erreurs_a_eviter: Array.isArray(persona.conseils_commerciaux?.erreurs_a_eviter) ? persona.conseils_commerciaux.erreurs_a_eviter.join(' | ') : persona.conseils_commerciaux?.erreurs_a_eviter || '',\n    prochaine_action: persona.conseils_commerciaux?.prochaine_action || '',\n\n    date_generation: new Date().toISOString()\n  }\n};"
      },
